{
  "name": "@manasdb/core",
  "version": "0.3.0",
  "description": "Hybrid retrieval and semantic memory engine for MongoDB Atlas (RAG, embeddings, vector search)",
  "main": "dist/index.cjs",
  "exports": {
    ".": "./dist/index.cjs",
    "./src": "./src/index.js"
  },
  "type": "module",
  "author": "ManasDB Contributors",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/manasdb/manasdb#readme",
  "bugs": {
    "url": "https://github.com/manasdb/manasdb/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/manasdb/manasdb.git"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "ai",
    "mongodb",
    "vector-database",
    "semantic-search",
    "rag",
    "embeddings",
    "llm",
    "retrieval",
    "ai-memory",
    "nodejs"
  ],
  "bin": {
    "manas": "./bin/manas.js"
  },
  "scripts": {
    "test:random": "node tests/test-large-random.js",
    "test:features": "node tests/test-features.js",
    "test:e2e": "node tests/test-e2e.js",
    "test:all": "node cleanup.js && npm run test:random && node cleanup.js && npm run test:features && node cleanup.js && npm run test:e2e",
    "health": "node src/health.js",
    "build": "node build.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@xenova/transformers": "^2.6.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^16.0.0",
    "mongodb": "^6.0.0",
    "ollama": "^0.5.0",
    "openai": "^6.25.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "bytenode": "^1.5.7",
    "esbuild": "^0.27.3",
    "javascript-obfuscator": "^5.3.0"
  }
}
